# Server
PORT=3001
NODE_ENV=development
PUBLIC_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://hazal:hazal@localhost:5434/hazal_muti?schema=public

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=365d

# Admin seed (used by `yarn prisma:seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Hazal Muti
ADMIN_PHONE=+905325127628

# Frontend (used for Google OAuth redirect after login + Hero links)
FRONTEND_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# OpenAI — for AI-assisted listing descriptions / translations / reply drafts
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Branding (used in 2FA QR codes and emails)
APP_NAME=Hazal Muti Real Estate

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Redis (optional — reserved for future use: queues, socket scaling, caching)
REDIS_URL=redis://localhost:6381

# SMTP — for new-inquiry email notifications.
# Production uses CyberPanel mail (info@hazalmuti.com on mail.hazalmuti.com:465 SSL).
# In dev, leave blank → emails are logged to console (admin still gets in-app notifications).
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Hazal Muti Real Estate <info@hazalmuti.com>

# OneSignal — web push notifications (admin → broadcast to all subscribers)
# https://dashboard.onesignal.com → app → Settings → Keys & IDs
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

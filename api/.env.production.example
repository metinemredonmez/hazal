# Production env template — copy to .env.production on the server (not committed).
# IMPORTANT: Postgres + Redis run as native services on the server, NOT in Docker.

PORT=3001
NODE_ENV=production
PUBLIC_URL=https://api.hazalmuti.com
CORS_ORIGINS=https://hazalmuti.com,https://www.hazalmuti.com

# Native postgres on the server
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/hazal_muti?schema=public&sslmode=disable

# Native redis on the server
REDIS_URL=redis://127.0.0.1:6379

# Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=365d

# Used only by `prisma:seed`. After first seed, change password via /api/auth/change-password.
ADMIN_EMAIL=hazalmuti@hotmail.com
ADMIN_PASSWORD=CHANGE_ME_AFTER_FIRST_LOGIN
ADMIN_NAME=Hazal Muti
ADMIN_PHONE=+905325127628

FRONTEND_URL=https://hazalmuti.com

# Google OAuth — production credentials from console.cloud.google.com
# Authorized redirect URI on prod: https://api.hazalmuti.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.hazalmuti.com/api/auth/google/callback

# OpenAI — production key from platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

APP_NAME=Hazal Muti Real Estate

# In production, mount a persistent volume here (e.g. /var/lib/hazal-muti/uploads)
UPLOAD_DIR=/var/lib/hazal-muti/uploads
MAX_FILE_SIZE_MB=10

# SMTP — CyberPanel mail (info@hazalmuti.com)
# Test on the server with: openssl s_client -connect mail.hazalmuti.com:465 -starttls smtp
SMTP_HOST=mail.hazalmuti.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@hazalmuti.com
SMTP_PASS=
MAIL_FROM=Hazal Muti Real Estate <info@hazalmuti.com>

# OneSignal — web push (admin broadcast + auto on listing publish)
# https://dashboard.onesignal.com → app → Settings → Keys & IDs
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Cron secret — for monthly report. Set up VPS crontab:
#   5 9 1 * * curl -fsSL -X POST -H "x-cron-secret: $CRON_SECRET" https://api.hazalmuti.com/api/cron/monthly-report
# Generate with: openssl rand -hex 32
CRON_SECRET=

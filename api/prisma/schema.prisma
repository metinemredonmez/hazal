// Hazal Muti Real Estate — Prisma schema
// Single broker, multilingual (TR/EN), Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  RENTED
  PASSIVE
}

enum ListingType {
  SALE
  RENT
}

enum ListingCategory {
  APARTMENT
  VILLA
  HOUSE
  LAND
  OFFICE
  COMMERCIAL
  OTHER
}

enum Currency {
  TRY
  USD
  EUR
}

enum InquiryStatus {
  NEW
  CONTACTED
  HOT
  CLOSED
}

enum ChatSender {
  VISITOR
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Admin {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String
  name                 String
  phone                String?
  avatarUrl            String?
  role                 AdminRole  @default(ADMIN)
  googleId             String?    @unique
  totpSecret           String?
  totpEnabled          Boolean    @default(false)
  pendingTotpSecret    String?
  tokenVersion         Int        @default(0)
  failedLoginAttempts  Int        @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  auditLogs            AuditLog[]
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "new_inquiry" | "new_chat_message" | "system"
  title     String
  body      String?
  link      String?
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?

  @@index([read, createdAt])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action    String
  success   Boolean  @default(true)
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model Appointment {
  id          String            @id @default(cuid())
  startsAt    DateTime
  durationMin Int               @default(60)
  name        String
  email       String?
  phone       String?
  listingId   String?
  listing     Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  inquiryId   String?
  inquiry     Inquiry?          @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  status      AppointmentStatus @default(SCHEDULED)
  location    String?
  notes       String?
  documents   Document[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([startsAt])
  @@index([status])
  @@index([listingId])
}

model Listing {
  id            String          @id @default(cuid())
  slug          String          @unique
  titleTr       String
  titleEn       String
  descriptionTr String
  descriptionEn String
  price         Decimal         @db.Decimal(14, 2)
  currency      Currency        @default(TRY)
  type          ListingType
  category      ListingCategory
  bedrooms      Int?
  bathrooms     Int?
  areaM2        Float?
  address       String?
  city          String?
  district      String?
  lat           Float?
  lng           Float?
  yearBuilt     Int?
  status        ListingStatus   @default(DRAFT)
  featured      Boolean         @default(false)
  views         Int             @default(0)
  videoUrl      String?
  tourUrl       String?
  metaTitleTr   String?
  metaTitleEn   String?
  metaDescTr    String?
  metaDescEn    String?
  images        ListingImage[]
  inquiries     Inquiry[]
  appointments  Appointment[]
  documents     Document[]
  calendarEvents CalendarEvent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([featured])
  @@index([type])
  @@index([category])
  @@index([city])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Inquiry {
  id           String        @id @default(cuid())
  name         String
  email        String
  phone        String?
  message      String
  status       InquiryStatus @default(NEW)
  notes        String?
  listingId    String?
  listing      Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  documents    Document[]
  calendarEvents CalendarEvent[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([listingId])
}

model ChatSession {
  id           String        @id @default(cuid())
  visitorId    String        @unique
  visitorName  String?
  visitorEmail String?
  closed       Boolean       @default(false)
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([closed])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    ChatSender
  content   String
  read      Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model SiteSettings {
  id              String   @id @default("singleton")
  brandName       String   @default("Hazal Muti Real Estate")
  tagline         String?
  logoUrl         String?
  primaryColor    String   @default("#1a1a1a")
  accentColor     String   @default("#c9a96e")
  phone           String?
  email           String?
  whatsapp        String?
  address         String?
  instagram       String?
  linkedin        String?
  youtube         String?
  facebook        String?
  defaultCurrency Currency @default(TRY)
  defaultLocale   String   @default("tr")
  mapboxToken     String?
  gaId            String?
  heroTitleTr     String?
  heroTitleEn     String?
  heroSubtitleTr  String?
  heroSubtitleEn  String?
  heroMediaUrl    String?
  aboutTr         String?
  aboutEn         String?
  seoTitleTr      String?
  seoTitleEn      String?
  seoDescTr       String?
  seoDescEn       String?
  // Page-specific editable copy (homepage sections, hakkimizda, iletisim).
  // Shape: see PageContent type in api/src/settings/page-content.types.ts
  pageContent     Json?
  // Email templates: { newInquiryAdmin: { subjectTr/En, bodyTr/En }, inquiryAutoReply: {...}, ... }
  emailTemplates  Json?
  updatedAt       DateTime @updatedAt
}

enum CalendarEventType {
  OPEN_HOUSE        // Açık ev
  LISTING_EXPIRY    // İlan süresi dolacak
  CONTRACT_END      // Kira/satış sözleşmesi bitiş
  PAYMENT_DUE       // Kira tahsilat tarihi
  INSPECTION        // Ekspertiz / muayene
  MARKETING_ACTION  // Pazarlama aksiyonu (post, kampanya)
  PLANNED_VISIT     // Planlanan ziyaret (haritaya bağlı)
  REMINDER          // Genel hatırlatma
  OTHER
}

enum CalendarEventStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

model CalendarEvent {
  id           String              @id @default(uuid())
  type         CalendarEventType
  status       CalendarEventStatus @default(PLANNED)
  title        String
  description  String?
  startsAt     DateTime
  endsAt       DateTime?
  allDay       Boolean             @default(false)
  color        String?

  // Konum
  location     String?
  lat          Float?
  lng          Float?

  // Bağlantılar — opsiyonel
  listingId    String?
  listing      Listing?            @relation(fields: [listingId], references: [id], onDelete: SetNull)
  inquiryId    String?
  inquiry      Inquiry?            @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  customerName String?

  // Hatırlatma (gün önce)
  remindBefore Int?                // dakika cinsinden

  // Tekrarlanma (basit cron-ish)
  recurrence   String?             // 'monthly' | 'weekly' | null

  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([startsAt])
  @@index([type, status])
  @@index([listingId])
}

enum DocumentCategory {
  CONTRACT       // Sözleşme
  IDENTITY       // Kimlik / pasaport
  DEED           // Tapu
  BLUEPRINT      // Mimari plan / ruhsat
  PHOTO          // Ek foto (ilan dışı)
  INVOICE        // Fatura
  BROCHURE       // Brosür
  OTHER
}

model Document {
  id           String           @id @default(uuid())
  title        String
  category     DocumentCategory
  fileUrl      String
  fileName     String
  fileSize     Int
  mimeType     String
  description  String?

  // Bağlantılar — hepsi opsiyonel
  listingId    String?
  listing      Listing?         @relation(fields: [listingId], references: [id], onDelete: SetNull)
  inquiryId    String?
  inquiry      Inquiry?         @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  appointmentId String?
  appointment  Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customerName String?

  tags         String[]         @default([])
  version      Int              @default(1)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category, createdAt])
  @@index([listingId])
  @@index([inquiryId])
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum BlogPostKind {
  ARTICLE   // own writing
  PRESS     // press coverage / media mention
  VIDEO     // video tour or interview
}

model BlogPost {
  id           String          @id @default(uuid())
  slug         String          @unique
  kind         BlogPostKind    @default(ARTICLE)
  status       BlogPostStatus  @default(DRAFT)
  titleTr      String
  titleEn      String
  excerptTr    String?
  excerptEn    String?
  bodyTr       String          @default("")
  bodyEn       String          @default("")
  coverImage   String?
  externalUrl  String?         // for PRESS/VIDEO that link out
  publishedAt  DateTime?
  views        Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, publishedAt])
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailStatus {
  UNREAD
  READ
  DELETED
}

model EmailMessage {
  id           String          @id @default(uuid())
  direction    EmailDirection
  status       EmailStatus     @default(UNREAD)
  // IMAP unique-id within a folder — used for dedup on fetch
  imapUid      String?
  imapFolder   String          @default("INBOX")
  messageId    String?         // RFC 822 Message-ID
  inReplyTo    String?
  threadKey    String?         // normalized subject+participants for grouping

  fromAddress  String
  fromName     String?
  toAddresses  String          // comma-separated
  ccAddresses  String?
  subject      String          @default("")
  bodyText     String          @default("")
  bodyHtml     String          @default("")
  hasAttachment Boolean        @default(false)

  receivedAt   DateTime        @default(now())
  fetchedAt    DateTime        @default(now())
  createdAt    DateTime        @default(now())

  @@unique([imapFolder, imapUid])
  @@index([direction, status, receivedAt])
  @@index([threadKey, receivedAt])
}

model ReportRun {
  id           String   @id @default(uuid())
  type         String   // "monthly"
  periodStart  DateTime
  periodEnd    DateTime
  data         Json
  emailSentTo  String?
  emailSentAt  DateTime?
  createdAt    DateTime @default(now())

  @@unique([type, periodStart])
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  locale      String   @default("tr")
  source      String   @default("web") // web, footer, popup, manual
  unsubscribed Boolean @default(false)
  unsubscribedAt DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([unsubscribed, createdAt])
}
